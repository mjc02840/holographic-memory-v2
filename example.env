# Holographic Memory v2.0 - Example Configuration
# Copy this to ~/.claude/memory/.env and customize

# Base directory for all memory files
export MEMORY_PATH="$HOME/.claude/memory"

# Database path (FTS5 + tracking)
export MEMORY_DB="$MEMORY_PATH/indexed.db"

# Fossil repository path
export MEMORY_FOSSIL="$MEMORY_PATH/context.fossil"

# Work hours (when to run ingest)
# Start: 10 = 10 AM
# End: 26 = 2 AM next day (10 AM to 2 AM = 18 hours)
export MEMORY_WORK_START=10
export MEMORY_WORK_END=26

# Alternative configurations:
# All day (24/7):
#   export MEMORY_WORK_START=0
#   export MEMORY_WORK_END=24
#
# Business hours (9 AM to 6 PM):
#   export MEMORY_WORK_START=9
#   export MEMORY_WORK_END=18
#
# Night owl (2 PM to 2 AM):
#   export MEMORY_WORK_START=14
#   export MEMORY_WORK_END=26
